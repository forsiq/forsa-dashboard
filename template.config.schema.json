{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ZoneVast Template Configuration",
  "type": "object",
  "required": ["template", "paths"],
  "properties": {
    "template": {
      "type": "object",
      "required": ["name", "version", "minCompatibleProject"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Template name"
        },
        "version": {
          "type": "string",
          "description": "Current template version (semver)",
          "pattern": "^\\d+\\.\\d+\\.\\d+"
        },
        "minCompatibleProject": {
          "type": "string",
          "description": "Minimum compatible project version",
          "pattern": "^\\d+\\.\\d+\\.\\d+"
        },
        "changelog": {
          "type": "string",
          "description": "Description of changes in this version"
        }
      }
    },
    "paths": {
      "type": "object",
      "properties": {
        "core": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Paths that are locked and come from template"
        },
        "config": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Configuration file paths"
        },
        "userEditable": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Paths users can edit"
        },
        "customZone": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Paths for user overrides"
        }
      }
    },
    "subtree": {
      "type": "object",
      "properties": {
        "prefix": {
          "type": "string",
          "description": "Subtree prefix in child projects"
        },
        "branch": {
          "type": "string",
          "description": "Default branch name"
        }
      }
    }
  }
}
