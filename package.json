{
  "name": "zonevast-template",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "ZoneVast Template Project - Feature-based architecture for rapid development",
  "scripts": {
    "dev": "vite --port 4000",
    "build": "tsc -b && vite build",
    "build:check": "npm run build && node scripts/check-translations.cjs",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx",
    "translations:check": "node scripts/check-translations.cjs",
    "translations:detect": "node scripts/detect-translations.cjs",
    "template:init": "node scripts/template-init.cjs",
    "template:sync": "node scripts/template-sync.cjs",
    "template:version": "node scripts/template-version.cjs",
    "template:status": "node scripts/template-status.cjs",
    "template:upgrade": "npm run template:sync && npm install"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.2",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.18",
    "file-saver": "^2.0.5",
    "framer-motion": "^11.2.10",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.475.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^7.1.5",
    "recharts": "^2.15.1",
    "tailwind-merge": "^2.5.2",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/file-saver": "^2.0.7",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.53.1",
    "vite": "^6.2.0"
  }
}
